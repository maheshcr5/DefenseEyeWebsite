# ─── DefenseEye.ai — Environment Variables ───────────────────────────────────
# Copy this file to .env and fill in your values before building/deploying.
# NEVER commit .env to version control.

# ── Server ────────────────────────────────────────────────────────────────────
# Port the Express server listens on (Nginx proxies from 80/443 to this port)
PORT=3000

# Node environment — set to "production" on the VPS
NODE_ENV=production

# ── Google Analytics 4 ────────────────────────────────────────────────────────
# Get this from Google Analytics → Admin → Data Streams → Measurement ID
# Format: G-XXXXXXXXXX
# Leave blank to disable GA4 (Umami will still run)
VITE_GA4_MEASUREMENT_ID=G-XXXXXXXXXX

# ── Umami Analytics (privacy-first, no cookie consent required) ──────────────
# Self-host Umami or use Umami Cloud (https://umami.is)
# VITE_ANALYTICS_ENDPOINT: your Umami instance URL (no trailing slash)
# VITE_ANALYTICS_WEBSITE_ID: the website ID from your Umami dashboard
VITE_ANALYTICS_ENDPOINT=https://analytics.defenseeye.ai
VITE_ANALYTICS_WEBSITE_ID=your-umami-website-id-here

# ── Domain (used in build-time SEO if needed) ─────────────────────────────────
VITE_SITE_URL=https://defenseeye.ai
